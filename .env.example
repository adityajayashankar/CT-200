# Copy this file to .env, then set your provider credentials.
# .env is ignored by Git; never commit a real API key.
LLM_API_KEY=
LLM_MODEL=
# Groq is the default. Set this for another OpenAI-compatible provider.
# LLM_BASE_URL=https://api.groq.com/openai/v1

# MongoDB Atlas configuration. Keep real credentials in .env only.
# Either set MONGODB_URI, or set the username, password, and cluster host below.
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_USERNAME=your-mongodb-username
MONGODB_PASSWORD=your-mongodb-password
MONGODB_HOST=cluster.example.mongodb.net
MONGODB_DATABASE=ct200
MONGODB_COLLECTION=generations
